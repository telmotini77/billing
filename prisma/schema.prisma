datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/billing-client"
}

model BillingInvoice {
  id          String              @id @default(uuid())
  claveAcceso String              @unique
  clientName  String
  amount      Float
  subtotal    Float
  iva         Float
  status      String              @default("RECEIVED")
  sentToClient Boolean             @default(false)
  userId      String
  createdAt   DateTime            @default(now())
  items       BillingInvoiceItem[]
}

model BillingInvoiceItem {
  id        String         @id @default(uuid())
  invoiceId String
  invoice   BillingInvoice @relation(fields: [invoiceId], references: [id])
  productId String
  quantity  Int
}

model User {
  id        String   @id
  email     String   @unique
  password  String
  name      String
  ruc       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  sriSimulate       Boolean @default(true)
  sriEnvironment    String  @default("1")
  signatureBase64   String?
  signaturePassword String?
  
  isBranch             Boolean @default(false)
  parentCompanyRuc     String?
  establishmentCode    String  @default("001")
  emissionPoint        String  @default("002")
  establishmentAddress String  @default("Av. de los Granados N45 y Eloy Alfaro, Quito")

  employees        Employee[]

  @@map("users")
}

model Employee {
  id        String   @id
  name      String
  email     String   @unique
  password  String   
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("employees")
}

